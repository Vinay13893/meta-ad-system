# Supabase project (Settings → API)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Meta Marketing API — System User token (long-lived, never expires)
META_ACCESS_TOKEN=
# Ad account ID — digits only, no "act_" prefix (we add it in code)
META_AD_ACCOUNT_ID=

# Shopify Admin API — shop domain and custom-app token
SHOPIFY_SHOP_DOMAIN=yourstore.myshopify.com
SHOPIFY_ADMIN_TOKEN=

# Email delivery (Gmail App Password)
# Setup: myaccount.google.com/apppasswords → create password for "Mail"
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
BRIEF_RECIPIENT_EMAIL=

# ── Optional: only needed to run apply_migrations.py locally ─────────────────
# Simpler alternative: paste migrations/*.sql into Supabase Dashboard → SQL Editor.
# Get this from: Supabase Dashboard → Settings → Database → URI
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
